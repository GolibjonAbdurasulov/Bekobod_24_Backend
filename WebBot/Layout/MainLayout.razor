@inherits LayoutComponentBase
@inject AuthState Auth
@inject CartState Cart
@inject TelegramService Telegram
@inject NavigationManager Nav

<div class="app-shell">
    <header class="app-bar">
        <a href="/" class="app-title">Bekobod 24</a>
        <div class="app-bar-actions">
            <a href="/cart" class="nav-icon">
                <span class="badge" style="display:@(Cart.TotalItems > 0 ? "inline" : "none")">@Cart.TotalItems</span>
                &#128722;
            </a>
            @if (Auth.IsLoggedIn)
            {
                <button class="btn-link nav-icon" @onclick="Logout">&#128682;</button>
            }
        </div>
    </header>

    <main class="app-content">
        @Body
    </main>

    @if (showNav)
    {
        <nav class="bottom-nav">
            <a href="/" class="bottom-nav-item">
                <span>&#127968;</span>
                <small>Home</small>
            </a>
            <a href="/cart" class="bottom-nav-item">
                <span>&#128722;</span>
                <small>Cart</small>
            </a>
            <a href="/orders" class="bottom-nav-item">
                <span>&#128230;</span>
                <small>Orders</small>
            </a>
            <a href="/courier" class="bottom-nav-item">
                <span>&#128666;</span>
                <small>Courier</small>
            </a>
        </nav>
    }
</div>

@code {
    private bool showNav = true;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Telegram.InitAsync();
            if (Telegram.IsTelegram)
            {
                showNav = false;
                StateHasChanged();
            }
            Nav.LocationChanged += (_, _) => InvokeAsync(() => Telegram.ShowBackButtonAsync(true));
        }
    }

    private void Logout()
    {
        Auth.Logout();
    }
}
