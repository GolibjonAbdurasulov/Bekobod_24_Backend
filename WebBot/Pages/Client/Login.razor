@page "/client-login"
@inject ApiService Api
@inject AuthState Auth
@inject NavigationManager Nav

<PageTitle>Login - Bekobod 24</PageTitle>

<div class="page">
    <h1 class="page-title">@(isLogin ? "Login" : "Register")</h1>

    <div class="card">
        @if (isLogin)
        {
            <div class="form-group">
                <label>Phone</label>
                <input class="form-input" @bind="phone" placeholder="+998901234567" />
            </div>
            <div class="form-group">
                <label>Password</label>
                <input class="form-input" type="password" @bind="password" placeholder="Enter password" />
            </div>
            <button class="btn btn-primary btn-block" @onclick="LoginAsync" disabled="@submitting">
                @(submitting ? "Logging in..." : "Login")
            </button>
            <div style="text-align:center;margin-top:12px;">
                <a href="javascript:void(0)" @onclick="() => isLogin = false" style="color:var(--primary);font-size:13px;">
                    Don't have an account? Register
                </a>
            </div>
        }
        else
        {
            <div class="form-group">
                <label>Full Name</label>
                <input class="form-input" @bind="fullName" placeholder="Your name" />
            </div>
            <div class="form-group">
                <label>Phone</label>
                <input class="form-input" @bind="phone" placeholder="+998901234567" />
            </div>
            <div class="form-group">
                <label>Password</label>
                <input class="form-input" type="password" @bind="password" placeholder="At least 6 characters" />
            </div>
            <button class="btn btn-primary btn-block" @onclick="RegisterAsync" disabled="@submitting">
                @(submitting ? "Registering..." : "Register")
            </button>
            <div style="text-align:center;margin-top:12px;">
                <a href="javascript:void(0)" @onclick="() => isLogin = true" style="color:var(--primary);font-size:13px;">
                    Already have an account? Login
                </a>
            </div>
        }

        @if (!string.IsNullOrEmpty(error))
        {
            <div style="color:var(--error);margin-top:12px;text-align:center;">@error</div>
        }
    </div>
</div>

@code {
    private bool isLogin = true;
    private string fullName = "";
    private string phone = "";
    private string password = "";
    private string error = "";
    private bool submitting;

    private async Task LoginAsync()
    {
        if (string.IsNullOrWhiteSpace(phone) || string.IsNullOrWhiteSpace(password))
        {
            error = "Please fill all fields";
            return;
        }

        submitting = true;
        error = "";

        try
        {
            var result = await Api.LoginAsync(new LoginRequest { Phone = phone, Password = password });
            if (result != null)
            {
                Nav.NavigateTo("/");
            }
            else
            {
                error = "Invalid phone or password";
            }
        }
        catch
        {
            error = "Connection error. Please try again.";
        }
        finally
        {
            submitting = false;
        }
    }

    private async Task RegisterAsync()
    {
        if (string.IsNullOrWhiteSpace(fullName) || string.IsNullOrWhiteSpace(phone) || string.IsNullOrWhiteSpace(password))
        {
            error = "Please fill all fields";
            return;
        }

        submitting = true;
        error = "";

        try
        {
            var result = await Api.RegisterAsync(new RegisterRequest
            {
                FullName = fullName,
                Phone = phone,
                Password = password
            });

            if (result != null)
            {
                Nav.NavigateTo("/");
            }
            else
            {
                error = "Registration failed. Phone may already be registered.";
            }
        }
        catch
        {
            error = "Connection error. Please try again.";
        }
        finally
        {
            submitting = false;
        }
    }
}
