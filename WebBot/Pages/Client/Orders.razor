@page "/orders"
@inject ApiService Api
@inject AuthState Auth
@inject NavigationManager Nav

<PageTitle>My Orders - Bekobod 24</PageTitle>

<div class="page">
    <h1 class="page-title">My Orders</h1>

    @if (!Auth.IsLoggedIn)
    {
        <div class="empty-state">
            <div class="icon">&#128273;</div>
            <p>Please log in to view your orders</p>
            <a href="/client-login" class="btn btn-primary" style="margin-top:8px;">Login</a>
        </div>
        return;
    }

    @if (loading)
    {
        <div class="loading">Loading...</div>
    }
    else if (orders.Count == 0)
    {
        <div class="empty-state">
            <div class="icon">&#128230;</div>
            <p>No orders yet</p>
            <a href="/" class="btn btn-primary" style="margin-top:8px;">Start Shopping</a>
        </div>
    }
    else
    {
        @foreach (var order in orders)
        {
            <div class="order-card">
                <div class="order-header">
                    <span class="order-number">#@order.OrderNumber</span>
                    <span class="status status-@order.Status.ToLower()">@order.Status</span>
                </div>
                <div style="font-size:13px;color:var(--text-secondary);">
                    @order.CreatedAt.ToString("dd.MM.yyyy HH:mm")
                </div>
                <div style="margin-top:6px;">
                    @foreach (var item in order.Items)
                    {
                        <div style="display:flex;justify-content:space-between;font-size:13px;padding:2px 0;">
                            <span>@item.ProductName x@item.Quantity</span>
                            <span>@item.TotalPrice.ToString("N0") so'm</span>
                        </div>
                    }
                </div>
                <div style="display:flex;justify-content:space-between;margin-top:8px;padding-top:8px;border-top:1px solid var(--divider);font-weight:600;">
                    <span>Total</span>
                    <span style="color:var(--primary);">@order.TotalAmount.ToString("N0") so'm</span>
                </div>
                <div style="font-size:12px;color:var(--text-secondary);margin-top:4px;">
                    &#127968; @order.DeliveryAddress
                </div>
            </div>
        }
    }
</div>

@code {
    private List<Order> orders = new();
    private bool loading = true;

    protected override async Task OnInitializedAsync()
    {
        if (!Auth.IsLoggedIn) { loading = false; return; }

        try
        {
            orders = await Api.GetMyOrdersAsync();
        }
        finally
        {
            loading = false;
        }
    }
}
