@page "/courier/dashboard"
@inject ApiService Api
@inject AuthState Auth
@inject NavigationManager Nav

<PageTitle>Courier Dashboard - Bekobod 24</PageTitle>

<div class="page">
    @if (!Auth.IsCourier)
    {
        <div class="empty-state">
            <div class="icon">&#128273;</div>
            <p>Please log in as courier</p>
            <a href="/courier" class="btn btn-primary" style="margin-top:8px;">Login</a>
        </div>
        return;
    }

    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;">
        <h1 class="page-title" style="margin-bottom:0;">Dashboard</h1>
        <button class="btn btn-outline btn-sm" @onclick="Logout">Logout</button>
    </div>

    @if (profile != null)
    {
        <div class="card" style="display:flex;align-items:center;gap:12px;">
            <div style="width:48px;height:48px;border-radius:50%;background:var(--primary);color:white;display:flex;align-items:center;justify-content:center;font-size:22px;">
                @profile.FullName[0]
            </div>
            <div>
                <div style="font-weight:600;">@profile.FullName</div>
                <div style="font-size:13px;color:var(--text-secondary);">&#9733; @profile.Rating.ToString("F1") &middot; @profile.TotalDeliveries deliveries</div>
                <div style="font-size:12px;color:var(--success);">@(profile.IsAvailable ? "&#9679; Available" : "&#9679; Busy")</div>
            </div>
        </div>
    }

    <h3 style="margin:16px 0 8px;">Available Orders</h3>
    @if (availableLoading)
    {
        <div class="loading">Loading...</div>
    }
    else if (availableOrders.Count == 0)
    {
        <div class="empty-state" style="padding:20px;">
            <p>No available orders</p>
        </div>
    }
    else
    {
        @foreach (var order in availableOrders)
        {
            <div class="order-card">
                <div class="order-header">
                    <span class="order-number">#@order.OrderNumber</span>
                    <span class="status status-pending">@order.Status</span>
                </div>
                <div style="font-size:13px;color:var(--text-secondary);">Store: @order.StoreName</div>
                <div style="font-size:13px;color:var(--text-secondary);">&#127968; @order.DeliveryAddress</div>
                <div style="font-size:13px;color:var(--text-secondary);">&#128100; @order.ClientName &middot; @order.ClientPhone</div>
                <div style="display:flex;justify-content:space-between;align-items:center;margin-top:8px;">
                    <span style="font-weight:700;color:var(--primary);">@order.TotalAmount.ToString("N0") so'm</span>
                    <button class="btn btn-success btn-sm" @onclick="() => AcceptOrder(order.Id)">
                        Accept
                    </button>
                </div>
            </div>
        }
    }

    <h3 style="margin:16px 0 8px;">Active Orders</h3>
    @if (activeLoading)
    {
        <div class="loading">Loading...</div>
    }
    else if (activeOrders.Count == 0)
    {
        <div class="empty-state" style="padding:20px;">
            <p>No active orders</p>
        </div>
    }
    else
    {
        @foreach (var order in activeOrders)
        {
            <div class="order-card" style="border-left:3px solid var(--primary);">
                <div class="order-header">
                    <span class="order-number">#@order.OrderNumber</span>
                    <span class="status status-accepted">@order.Status</span>
                </div>
                <div style="font-size:13px;color:var(--text-secondary);">Store: @order.StoreName</div>
                <div style="font-size:13px;color:var(--text-secondary);">&#127968; @order.DeliveryAddress</div>
                <div style="font-size:13px;color:var(--text-secondary);">&#128100; @order.ClientName &middot; @order.ClientPhone</div>
                <div style="display:flex;justify-content:space-between;align-items:center;margin-top:8px;">
                    <span style="font-weight:700;">@order.TotalAmount.ToString("N0") so'm</span>
                    @if (order.Status == "Accepted")
                    {
                        <button class="btn btn-success btn-sm" @onclick="() => DeliverOrder(order.Id)">
                            Mark Delivered
                        </button>
                    }
                </div>
            </div>
        }
    }
</div>

@code {
    private CourierProfile? profile;
    private List<Order> availableOrders = new();
    private List<Order> activeOrders = new();
    private bool availableLoading = true;
    private bool activeLoading = true;

    protected override async Task OnInitializedAsync()
    {
        if (!Auth.IsCourier) { availableLoading = false; activeLoading = false; return; }
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            profile = await Api.GetCourierProfileAsync();
            availableOrders = await Api.GetAvailableOrdersAsync();
            activeOrders = await Api.GetCourierOrdersAsync();
        }
        catch { }
        finally
        {
            availableLoading = false;
            activeLoading = false;
        }
    }

    private async Task AcceptOrder(Guid orderId)
    {
        var ok = await Api.AcceptOrderAsync(orderId);
        if (ok) await LoadData();
    }

    private async Task DeliverOrder(Guid orderId)
    {
        var ok = await Api.DeliverOrderAsync(orderId);
        if (ok) await LoadData();
    }

    private void Logout()
    {
        Auth.Logout();
        Nav.NavigateTo("/courier");
    }
}
