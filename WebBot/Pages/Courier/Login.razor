@page "/courier"
@inject ApiService Api
@inject AuthState Auth
@inject NavigationManager Nav

<PageTitle>Courier - Bekobod 24</PageTitle>

<div class="page">
    @if (Auth.IsCourier)
    {
        Nav.NavigateTo("/courier/dashboard");
        return;
    }

    <h1 class="page-title">Courier Login</h1>

    <div class="card">
        <div class="form-group">
            <label>Phone</label>
            <input class="form-input" @bind="phone" placeholder="+998901234567" />
        </div>
        <div class="form-group">
            <label>Password</label>
            <input class="form-input" type="password" @bind="password" placeholder="Enter password" />
        </div>

        @if (!string.IsNullOrEmpty(error))
        {
            <div style="color:var(--error);margin-bottom:8px;text-align:center;">@error</div>
        }

        <button class="btn btn-primary btn-block" @onclick="LoginAsync" disabled="@submitting">
            @(submitting ? "Logging in..." : "Login")
        </button>
    </div>
</div>

@code {
    private string phone = "";
    private string password = "";
    private string error = "";
    private bool submitting;

    private async Task LoginAsync()
    {
        if (string.IsNullOrWhiteSpace(phone) || string.IsNullOrWhiteSpace(password))
        {
            error = "Please fill all fields";
            return;
        }

        submitting = true;
        error = "";

        try
        {
            var result = await Api.LoginAsync(new LoginRequest { Phone = phone, Password = password });
            if (result != null && result.Role == "Courier")
            {
                Nav.NavigateTo("/courier/dashboard");
            }
            else
            {
                error = "Invalid credentials or not a courier account";
            }
        }
        catch
        {
            error = "Connection error. Please try again.";
        }
        finally
        {
            submitting = false;
        }
    }
}
