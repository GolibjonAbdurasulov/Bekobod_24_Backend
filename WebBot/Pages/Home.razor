@page "/"
@inject ApiService Api
@inject NavigationManager Nav

<PageTitle>Bekobod 24</PageTitle>

<div class="page">
    <h1 class="page-title">Choose a category</h1>

    @if (loading)
    {
        <div class="loading">Loading...</div>
    }
    else
    {
        <div class="grid-2">
            @foreach (var st in storeTypes)
            {
                <div class="store-type-card" @onclick="() => Select(st)">
                    <div class="icon">@GetIcon(st.Name)</div>
                    <div class="name">@st.Name</div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<StoreType> storeTypes = new();
    private bool loading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            storeTypes = await Api.GetStoreTypesAsync();
        }
        finally
        {
            loading = false;
        }
    }

    private void Select(StoreType st)
    {
        Nav.NavigateTo($"/stores/{st.Id}/{Uri.EscapeDataString(st.Name)}");
    }

    private string GetIcon(string name)
    {
        return name.ToLower() switch
        {
            "supermarket" or "магазин" or "супермаркет" => "\ud83c\udfea",
            "pharmacy" or "apteka" or "аптека" => "\ud83d\udc8a",
            "restaurant" or "food" or "еда" => "\ud83c\udf54",
            "electronics" or "электроника" => "\ud83d\udcf1",
            "clothing" or "одежда" => "\ud83d\udc55",
            "fruits" or "овощи" or "фрукты" => "\ud83c\udf4e",
            _ => "\ud83d\udccd"
        };
    }
}
